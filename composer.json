{
    "name": "tukio/qrcode-generator",
    "description": "Batch Card QR Code Generator for Events",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "endroid/qr-code": "^5.0",
        "tecnickcom/tcpdf": "^6.6",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpmailer/phpmailer": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
